###############################################################################
# Evently — environment variables
#
# Copy this file to `.env.local` and fill in the values. `.env*` is gitignored
# (only `.env.example` is checked in). For Vercel deploys, run `./upload_env.sh`
# after populating `.env.local` to push values to the production environment.
###############################################################################

# -----------------------------------------------------------------------------
# Database (Postgres / Supabase)
# -----------------------------------------------------------------------------
# Pooled connection used by the runtime (PgBouncer / Supavisor on port 5432).
# DIRECT_URL bypasses the pooler — needed for `prisma migrate` and seed scripts.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/evently"
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:5432/evently"

# -----------------------------------------------------------------------------
# App URL — used for absolute links in emails, OG metadata, OAuth callbacks.
# In production, leave NEXT_PUBLIC_APP_URL empty and the app will derive it
# from VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Public values — exposed to the browser. Found in: Supabase Dashboard →
# Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
# Legacy alias for older clients; prefer PUBLISHABLE_KEY above.
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Server-only — bypasses RLS. Required for: image uploads, future Stripe
# webhook user lookups. NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=""

# Read-path toggle. When "supabase" + the public Supabase env above is set,
# /events and /events/[slug] read from Postgres via the Supabase JS client
# (subject to RLS). Otherwise the Prisma path is used.
NEXT_PUBLIC_EVENTS_SOURCE="supabase"

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
# Webhook signing secret. Get one per environment from:
#   Stripe Dashboard → Developers → Webhooks → endpoint → Signing secret
# In development, run `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# and use the `whsec_...` it prints.
STRIPE_WEBHOOK_SECRET=""

# -----------------------------------------------------------------------------
# Resend (transactional email)
# -----------------------------------------------------------------------------
RESEND_API_KEY=""
# MUST be a domain you've verified in Resend, otherwise sends will fail in
# production. The dev default `onboarding@resend.dev` only delivers to the
# Resend account owner.
RESEND_FROM_EMAIL=""

# -----------------------------------------------------------------------------
# Google Maps / Places
# -----------------------------------------------------------------------------
# Server key — used by /api/location/suggest for autocomplete + place details.
# Restrict by IP / referrer in the Google Cloud console.
GOOGLE_MAPS_SERVER_KEY=""
# Browser key — used by the Maps Embed iframe. Restrict by HTTP referrer.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# -----------------------------------------------------------------------------
# Upstash (rate limiting)
# -----------------------------------------------------------------------------
# Required in production. Without these, rate limiting silently no-ops and a
# warning is logged on first request. Sign up at https://upstash.com.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# -----------------------------------------------------------------------------
# Sentry (error monitoring)
# -----------------------------------------------------------------------------
# DSN exposes nothing sensitive — safe to expose to the browser.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
# Used by the build wrapper to upload sourcemaps. Without these, build still
# works but Sentry stack traces will be minified.
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
# Override the auto-detected environment string ("production" / "preview" / "development").
SENTRY_ENVIRONMENT=""
NEXT_PUBLIC_SENTRY_ENVIRONMENT=""
# 0.0–1.0; default 0.1. Tune down if event volume gets expensive.
SENTRY_TRACES_SAMPLE_RATE="0.1"
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"

# -----------------------------------------------------------------------------
# Mock catalog (development-only fallback)
# -----------------------------------------------------------------------------
# When "true", the public catalog reads from a hard-coded seed + the
# organizer-demo localStorage store. KEEP THIS "false" in production —
# leaving it on would route real users into client-only flows.
NEXT_PUBLIC_USE_MOCK_CATALOG="false"
