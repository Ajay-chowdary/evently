generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ATTENDEE
  ORGANIZER
  ADMIN
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum EventVisibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum TicketTypeStatus {
  DRAFT
  ACTIVE
  SOLD_OUT
  HIDDEN
  CANCELLED
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  REFUNDED
  FAILED
  EXPIRED
}

enum TicketStatus {
  ISSUED
  CANCELLED
  REFUNDED
  USED
  VOID
}

model User {
  id               String            @id @default(cuid())
  authUserId       String            @unique @db.Uuid
  email            String            @unique
  name             String?
  avatarUrl        String?
  role             UserRole          @default(ATTENDEE)
  stripeCustomerId String?           @unique
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  organizer        Organizer?
  savedEvents      SavedEvent[]
  bookings         Booking[]
  tickets          Ticket[]
  following        OrganizerFollow[] @relation("UserFollowingOrganizers")
}

model Organizer {
  id              String            @id
  handle          String            @unique
  name            String
  logoUrl         String?
  bio             String?
  verified        Boolean           @default(false)
  contactEmail    String
  socialLinks     Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  profile         User              @relation(fields: [id], references: [id], onDelete: Cascade)
  events          Event[]
  followers       OrganizerFollow[]
}

model OrganizerFollow {
  id          String    @id @default(cuid())
  followerId  String
  organizerId String
  createdAt   DateTime  @default(now())
  follower    User      @relation("UserFollowingOrganizers", fields: [followerId], references: [id], onDelete: Cascade)
  organizer   Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  @@unique([followerId, organizerId])
  @@index([organizerId, createdAt])
}

model Venue {
  id                String   @id @default(cuid())
  name              String
  addressLine1      String
  addressLine2      String?
  city              String
  state             String?
  country           String
  postalCode        String?
  latitude          Float?
  longitude         Float?
  capacity          Int?
  accessibilityInfo String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  events            Event[]

  @@index([city, state, country])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  icon        String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  events      Event[]
}

model Event {
  id               String          @id @default(cuid())
  organizerId      String
  venueId          String?
  categoryId       String?
  slug             String          @unique
  title            String
  subtitle         String?
  shortDescription String?
  description      String
  category         String
  city             String
  region           String?
  country          String?
  venueName        String?
  imageUrl         String
  galleryUrls      Json?
  tagline          String?
  heroSubtitle     String?
  presenterLine    String?
  organizerLogoUrl String?
  ticketPrice      Float           @default(0)
  ticketCurrency   String          @default("USD")
  salesEndsAt      DateTime?
  capacity         Int?
  ticketNote       String?
  status           EventStatus     @default(DRAFT)
  visibility       EventVisibility @default(PUBLIC)
  featured         Boolean         @default(false)
  startsAt         DateTime
  endsAt           DateTime?
  timezone         String          @default("UTC")
  ageRestriction   String?
  dressCode        String?
  refundPolicy     String?
  published        Boolean         @default(false)
  publishedAt      DateTime?
  cancelledAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  organizer        Organizer       @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  venue            Venue?          @relation(fields: [venueId], references: [id], onDelete: SetNull)
  categoryRef      Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags             EventTag[]
  faqItems         EventFAQ[]
  agendaItems      EventAgendaItem[]
  ticketTypes      TicketType[]
  bookings         Booking[]
  tickets          Ticket[]
  savedBy          SavedEvent[]

  @@index([organizerId, startsAt])
  @@index([published, startsAt])
  @@index([status, visibility, startsAt])
  @@index([city, startsAt])
  @@index([category, startsAt])
}

model EventTag {
  id        String   @id @default(cuid())
  eventId   String
  label     String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model EventFAQ {
  id        String   @id @default(cuid())
  eventId   String
  question  String
  answer    String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, sortOrder])
}

model EventAgendaItem {
  id          String   @id @default(cuid())
  eventId     String
  label       String
  startTime   DateTime?
  endTime     DateTime?
  description String?
  speaker     String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, sortOrder])
}

model TicketType {
  id                 String           @id @default(cuid())
  eventId            String
  name               String
  description        String?
  price              Float            @default(0)
  currency           String           @default("USD")
  inventoryTotal     Int
  inventoryRemaining Int
  minPerOrder        Int              @default(1)
  maxPerOrder        Int              @default(10)
  saleStart          DateTime?
  saleEnd            DateTime?
  status             TicketTypeStatus @default(ACTIVE)
  perks              Json?
  sortOrder          Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  event              Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  bookingLineItems   BookingLineItem[]
  tickets            Ticket[]

  @@index([eventId, sortOrder])
  @@index([eventId, status])
}

model Booking {
  id                      String        @id @default(cuid())
  referenceCode           String        @unique
  userId                  String
  eventId                 String
  status                  BookingStatus @default(PENDING_PAYMENT)
  subtotal                Float
  serviceFee              Float
  total                   Float
  currency                String
  stripeCheckoutSessionId String?       @unique
  stripePaymentIntentId   String?       @unique
  checkoutExpiresAt       DateTime?
  paidAt                  DateTime?
  cancelledAt             DateTime?
  failureReason           String?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  user                    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  event                   Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  lineItems               BookingLineItem[]
  tickets                 Ticket[]

  @@index([userId, createdAt])
  @@index([eventId, createdAt])
  @@index([status, createdAt])
}

model BookingLineItem {
  id             String     @id @default(cuid())
  bookingId      String
  ticketTypeId   String
  ticketTypeName String
  quantity       Int
  unitPrice      Float
  lineTotal      Float
  createdAt      DateTime   @default(now())
  booking        Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  ticketType     TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Restrict)

  @@index([bookingId])
  @@index([ticketTypeId])
}

model Ticket {
  id            String       @id @default(cuid())
  referenceCode String       @unique
  bookingId     String
  userId        String
  eventId       String
  ticketTypeId  String
  quantity      Int          @default(1)
  paymentMethod String       @default("stripe")
  attendeeName  String
  attendeeEmail String
  qrCodeValue   String       @unique
  status        TicketStatus @default(ISSUED)
  createdAt     DateTime     @default(now())
  issuedAt      DateTime     @default(now())
  usedAt        DateTime?
  booking       Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  event         Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketType    TicketType   @relation(fields: [ticketTypeId], references: [id], onDelete: Restrict)

  @@index([bookingId])
  @@index([userId, issuedAt])
  @@index([eventId, status])
}

model SavedEvent {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([userId, createdAt])
}
